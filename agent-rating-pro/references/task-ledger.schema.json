{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task Rating Pro Ledger",
  "type": "object",
  "required": ["updatedAt", "tasks"],
  "properties": {
    "updatedAt": {"type": "string"},
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "status", "createdAt"],
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "status": {"type": "string", "enum": ["PENDING", "IN_PROGRESS", "DONE", "SENT", "CANCELED"]},
          "ratings": {
            "type": ["object", "null"],
            "properties": {
              "performance": {"$ref": "#/$defs/rating"},
              "result": {"$ref": "#/$defs/rating"}
            },
            "additionalProperties": false
          },
          "feedback": {"type": ["string", "null"]},
          "execution": {"type": ["object", "null"], "additionalProperties": true},
          "results": {"type": ["object", "null"], "additionalProperties": true},
          "notes": {"type": ["string", "null"]},
          "tags": {"type": ["array", "null"], "items": {"type": "string"}},
          "createdAt": {"type": "string"},
          "updatedAt": {"type": ["string", "null"]},
          "completedAt": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "rating": {
      "type": ["object", "null"],
      "required": ["stars"],
      "properties": {
        "stars": {"type": ["integer", "null"], "minimum": 1, "maximum": 5},
        "rationale": {"type": ["string", "null"]},
        "whatWorked": {"type": ["array", "null"], "items": {"type": "string"}},
        "whatToChange": {"type": ["array", "null"], "items": {"type": "string"}}
      },
      "additionalProperties": false
    }
  }
}
